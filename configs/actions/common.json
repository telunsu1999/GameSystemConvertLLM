{
  "actions": {
    "greet": {
      "description": "向玩家打招呼，表示友好",
      "effect": "记录社交事件",
      "steps": [
        {"type":"record_event", "event_type":"npc_greet_player", "event_tags":["social"]}
      ]
    },
    "eat": {
      "description": "消耗1份食物，恢复5点生命值",
      "effect": "食物-1，生命+5",
      "check": [{"field":"food_owned","op":"gt","value":0}],
      "steps": [
        {"type":"sub_attr", "field":"food_owned", "value":1},
        {"type":"add_attr", "field":"hp", "value":5},
        {"type":"record_event", "event_type":"npc_eat", "event_tags":["daily"]}
      ]
    },
    "sleep": {
      "description": "开始睡觉，恢复体力",
      "effect": "设置睡眠状态，停止移动",
      "steps": [
        {"type":"set_attr", "field":"sleeping", "value":1},
        {"type":"set_attr", "field":"moving", "value":0},
        {"type":"record_event", "event_type":"npc_sleep", "event_tags":["daily"]}
      ]
    },
    "wake": {
      "description": "起床，恢复50点体力",
      "effect": "体力+50，清除睡眠状态",
      "steps": [
        {"type":"set_attr", "field":"sleeping", "value":0},
        {"type":"add_attr", "field":"stamina", "value":50},
        {"type":"record_event", "event_type":"npc_wake", "event_tags":["daily"]}
      ]
    },
    "work": {
      "description": "进行工作赚取金币，需要指定收入金额",
      "effect": "金币+{income}，体力-5",
      "params": [{"name":"income","type":"number","description":"收入的金币数量，通常5-15"}],
      "steps": [
        {"type":"add_attr", "field":"gold", "value":"{params.income}"},
        {"type":"sub_attr", "field":"stamina", "value":5},
        {"type":"record_event", "event_type":"npc_work", "event_tags":["daily","work"]}
      ]
    },
    "heal": {
      "description": "使用治疗物品恢复生命值",
      "effect": "生命+{amount}",
      "check": [{"field":"hp","op":"lt","value":"{attr.hp_max}"}],
      "params": [{"name":"amount","type":"number","description":"恢复的生命值，通常10-30"}],
      "steps": [
        {"type":"add_attr", "field":"hp", "value":"{params.amount}"},
        {"type":"record_event", "event_type":"npc_heal", "event_tags":["combat"]}
      ]
    },
    "wander": {
      "description": "四处闲逛，探索周围环境",
      "effect": "设置游荡状态",
      "steps": [
        {"type":"set_attr", "field":"wandering", "value":1},
        {"type":"record_event", "event_type":"npc_wander", "event_tags":["travel"]}
      ]
    },
    "drink": {
      "description": "去酒馆喝酒，消耗5金币",
      "effect": "金币-5，设置醉酒状态",
      "check": [{"field":"gold","op":"gte","value":5}],
      "steps": [
        {"type":"sub_attr", "field":"gold", "value":5},
        {"type":"set_attr", "field":"drunk", "value":1},
        {"type":"record_event", "event_type":"npc_drink", "event_tags":["social"]}
      ]
    },
    "defend": {
      "description": "进入防御姿态",
      "effect": "设置防御状态",
      "steps": [
        {"type":"set_attr", "field":"defending", "value":1},
        {"type":"record_event", "event_type":"npc_defend", "event_tags":["combat"]}
      ]
    },
    "attack": {
      "description": "攻击指定目标",
      "effect": "对{target}造成{damage}点伤害，体力-5",
      "check": [{"field":"hp","op":"gt","value":0}],
      "params": [
        {"name":"target","type":"string","description":"攻击目标"},
        {"name":"damage","type":"number","description":"造成的伤害值，通常10-30"}
      ],
      "steps": [
        {"type":"sub_attr", "field":"stamina", "value":5},
        {"type":"record_event", "event_type":"npc_attack", "event_tags":["combat"],
         "event_data":{"target":"{params.target}","damage":"{params.damage}"}}
      ]
    },

    "morning_routine": {
      "description": "早晨起来吃早饭，补充体力准备一天的工作",
      "effect": "体力+10，食物-1",
      "steps": [
        {"type":"add_attr", "field":"stamina", "value":10},
        {"type":"sub_attr", "field":"food_owned", "value":1},
        {"type":"record_event", "event_type":"npc_morning_routine", "event_tags":["daily","work"]}
      ]
    },
    "morning_work": {
      "description": "上午努力工作锻造铁器",
      "effect": "金币+10，体力-8",
      "steps": [
        {"type":"add_attr", "field":"gold", "value":10},
        {"type":"sub_attr", "field":"stamina", "value":8},
        {"type":"record_event", "event_type":"npc_forge", "event_tags":["daily","work"]}
      ]
    },
    "afternoon_work": {
      "description": "下午继续工作，效率更高",
      "effect": "金币+12，体力-6",
      "steps": [
        {"type":"add_attr", "field":"gold", "value":12},
        {"type":"sub_attr", "field":"stamina", "value":6},
        {"type":"record_event", "event_type":"npc_afternoon_work", "event_tags":["daily","work"]}
      ]
    },
    "evening_routine": {
      "description": "收工后去酒馆喝一杯",
      "effect": "金币-5，体力-3，进入醉酒状态",
      "steps": [
        {"type":"sub_attr", "field":"gold", "value":5},
        {"type":"set_attr", "field":"drunk", "value":1},
        {"type":"sub_attr", "field":"stamina", "value":3},
        {"type":"record_event", "event_type":"npc_evening", "event_tags":["daily","rest"]}
      ]
    },
    "morning_business": {
      "description": "上午开门营业",
      "effect": "金币+15，体力-5",
      "steps": [
        {"type":"add_attr", "field":"gold", "value":15},
        {"type":"sub_attr", "field":"stamina", "value":5},
        {"type":"record_event", "event_type":"npc_trade_morning", "event_tags":["daily","trade"]}
      ]
    },
    "afternoon_business": {
      "description": "下午继续做生意，客流量更大",
      "effect": "金币+20，体力-6",
      "steps": [
        {"type":"add_attr", "field":"gold", "value":20},
        {"type":"sub_attr", "field":"stamina", "value":6},
        {"type":"record_event", "event_type":"npc_trade_afternoon", "event_tags":["daily","trade"]}
      ]
    }
  }
}
